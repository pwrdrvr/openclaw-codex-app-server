    },
    "requestTimeoutMs": {
      "label": "Request Timeout (ms)",
      "advanced": true
    },
    "inputTimeoutMs": {
      "label": "Input Timeout (ms)",
      "advanced": true
    },
    "defaultWorkspaceDir": {
      "label": "Default Workspace Dir"
    },
    "defaultModel": {
      "label": "Default Model",
      "advanced": true
    },
    "defaultServiceTier": {
      "label": "Default Service Tier",
      "advanced": true
    }
  }
