    "headers": {
      "label": "Extra Headers",
      "advanced": true
    },
    "requestTimeoutMs": {
      "label": "Request Timeout (ms)",
      "advanced": true
    },
    "defaultEndpoint": {
      "label": "Default Endpoint",
      "advanced": true
    },
